void BoolVector::resize(size_t newSize, bool defaultValue) {
    if (newSize == numBits) return;
    
    size_t newNumBytes = (newSize + 7) / 8;
    unsigned char* newData = new unsigned char[newNumBytes];
    
    // Копируем существующие байты
    size_t copyBytes = numBytes < newNumBytes ? numBytes : newNumBytes;
    for (size_t i = 0; i < copyBytes; ++i) {
        newData[i] = data[i];
    }
    
    // Инициализируем новые байты
    unsigned char fillValue = defaultValue ? 0xFF : 0x00;
    for (size_t i = numBytes; i < newNumBytes; ++i) {
        newData[i] = fillValue;
    }
    
    // Если уменьшаем размер - чистим лишние биты в последнем байте
    if (newSize < numBits) {
        size_t bitsInLast = newSize % 8;
        if (bitsInLast != 0) {
            newData[newNumBytes - 1] &= (1 << bitsInLast) - 1;
        }
    }
    
    // Если увеличиваем размер и был неполный байт
    if (newSize > numBits && numBits % 8 != 0) {
        size_t bitsInLastOld = numBits % 8;
        if (!defaultValue) {
            newData[numBytes - 1] &= (1 << bitsInLastOld) - 1;
        }
    }
    
    delete[] data;
    data = newData;
    numBits = newSize;
    numBytes = newNumBytes;
}

void BoolVector::push_back(bool value) {
    resize(numBits + 1, value);
}

void BoolVector::pop_back() {
    if (numBits > 0) {
        resize(numBits - 1);
    }
}

void BoolVector::clear() {
    delete[] data;
    data = 0;
    numBits = 0;
    numBytes = 0;
}

void BoolVector::fill(bool value) {
    unsigned char fillValue = value ? 0xFF : 0x00;
    for (size_t i = 0; i < numBytes; ++i) {
        data[i] = fillValue;
    }
    
    size_t bitsInLast = numBits % 8;
    if (bitsInLast != 0) {
        if (value) {
            data[numBytes - 1] |= ~((1 << bitsInLast) - 1);
        } else {
            data[numBytes - 1] &= (1 << bitsInLast) - 1;
        }
    }
}



