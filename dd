#ifndef BOOL_VECTOR_HPP
#define BOOL_VECTOR_HPP

#include <cstddef>

class BoolVector {
private:
    unsigned char* data;  // массив для хранения битов
    size_t numBits;       // количество булевых значений
    size_t numBytes;      // количество байт, необходимых для хранения
    
    // Вспомогательные методы
    static unsigned char bitMask(size_t pos);
    static size_t byteIndex(size_t pos);
    
public:
    // Прокси-класс для поддержки записи через оператор []
    class Reference {
    private:
        unsigned char* byte;
        unsigned char mask;
        
    public:
        Reference(unsigned char* byte, unsigned char mask);
        
        Reference& operator=(bool value);
        operator bool() const;
        Reference& operator=(const Reference& other);
    };
    
    // Конструкторы и деструктор
    BoolVector();
    explicit BoolVector(size_t size, bool defaultValue = false);
    BoolVector(const BoolVector& other);
    ~BoolVector();
    
    // Операторы
    BoolVector& operator=(const BoolVector& other);
    Reference operator[](size_t index);
    bool operator[](size_t index) const;
    
    // Методы доступа
    size_t size() const;
    bool empty() const;
    
    // Методы модификации
    void resize(size_t newSize, bool defaultValue = false);
    void push_back(bool value);
    void pop_back();
    void clear();
    void fill(bool value);
};

#endif // BOOL_VECTOR_HPP



