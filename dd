#include <vector>
#include <stdexcept>

class BitVector {
private:
    std::vector<unsigned char> data; // Храним биты в массиве байтов
    size_t bitCount; // Общее количество битов

public:
    // Конструктор с указанием размера вектора
    explicit BitVector(size_t size = 0) : bitCount(size) {
        // Вычисляем, сколько байтов нужно для хранения заданного количества битов
        data.resize((size + 7) / 8);
    }

    // Метод для получения размера вектора
    size_t size() const {
        return bitCount;
    }

    // Вспомогательный класс для работы с отдельными битами
    class BitReference {
    private:
        unsigned char& byte; // Ссылка на байт, содержащий нужный бит
        unsigned char mask;   // Маска для доступа к конкретному биту

    public:
        BitReference(unsigned char& b, unsigned char m) : byte(b), mask(m) {}

        // Присвоение значения биту
        BitReference& operator=(bool value) {
            if (value) {
                byte |= mask; // Устанавливаем бит в 1
            } else {
                byte &= ~mask; // Устанавливаем бит в 0
            }
            return *this;
        }

        // Преобразование в bool
        operator bool() const {
            return (byte & mask) != 0;
        }
    };

    // Оператор доступа по индексу (для чтения и записи)
    BitReference operator[](size_t index) {
        if (index >= bitCount) {
            throw std::out_of_range("BitVector index out of range");
        }
        size_t byteIndex = index / 8;      // Номер байта
        unsigned char bitMask = 1 << (index % 8); // Маска для конкретного бита
        return BitReference(data[byteIndex], bitMask);
    }

    // Константный оператор доступа по индексу (только для чтения)
    bool operator[](size_t index) const {
        if (index >= bitCount) {
            throw std::out_of_range("BitVector index out of range");
        }
        size_t byteIndex = index / 8;
        unsigned char bitMask = 1 << (index % 8);
        return (data[byteIndex] & bitMask) != 0;
    }
};


int main() {
    BitVector vec(10); // Вектор из 10 битов

    vec[0] = true;
    vec[1] = false;
    vec[2] = true;

    for (size_t i = 0; i < vec.size(); ++i) {
        std::cout << vec[i] << " "; // Вывод: 1 0 1 0 0 0 0 0 0 0
    }
    std::cout << std::endl;

    return 0;
}




#include <stdexcept>
#include <cstring> // для memset

class BitVector {
private:
    unsigned char* data;    // Динамический массив байтов для хранения битов
    size_t bitCount;        // Общее количество битов в векторе
    size_t byteCapacity;    // Количество выделенных байтов

    // Вспомогательный класс для работы с отдельными битами
    class BitReference {
    private:
        unsigned char& byte;
        unsigned char mask;

    public:
        BitReference(unsigned char& b, unsigned char m) : byte(b), mask(m) {}

        // Присвоение значения биту
        BitReference& operator=(bool value) {
            if (value) {
                byte |= mask; // Устанавливаем бит в 1
            } else {
                byte &= ~mask; // Устанавливаем бит в 0
            }
            return *this;
        }

        // Преобразование в bool
        operator bool() const {
            return (byte & mask) != 0;
        }
    };

public:
    // Конструктор с указанием размера вектора
    explicit BitVector(size_t size = 0)
        : bitCount(size),
          byteCapacity((size + 7) / 8) {
        if (byteCapacity > 0) {
            data = new unsigned char[byteCapacity];
            // Инициализируем все биты нулями
            std::memset(data, 0, byteCapacity);
        } else {
            data = nullptr;
        }
    }

    // Деструктор — освобождаем память
    ~BitVector() {
        delete[] data;
    }

    // Запрещаем копирование (можно реализовать через правило пяти при необходимости)
    BitVector(const BitVector&) = delete;
    BitVector& operator=(const BitVector&) = delete;

    // Метод для получения размера вектора
    size_t size() const {
        return bitCount;
    }

    // Оператор доступа по индексу (для чтения и записи)
    BitReference operator[](size_t index) {
        if (index >= bitCount) {
            throw std::out_of_range("BitVector index out of range");
        }
        size_t byteIndex = index / 8;      // Номер байта
        unsigned char bitMask = 1 << (index % 8); // Маска для конкретного бита
        return BitReference(data[byteIndex], bitMask);
    }

    // Константный оператор доступа по индексу (только для чтения)
    bool operator[](size_t index) const {
        if (index >= bitCount) {
            throw std::out_of_range("BitVector index out of range");
        }
        size_t byteIndex = index / 8;
        unsigned char bitMask = 1 << (index % 8);
        return (data[byteIndex] & bitMask) != 0;
    }
};


