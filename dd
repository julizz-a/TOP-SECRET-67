// ============ Вспомогательные методы ============

unsigned char BoolVector::bitMask(size_t pos) {
    return 1 << (pos % 8);
}

size_t BoolVector::byteIndex(size_t pos) {
    return pos / 8;
}

// ============ Конструкторы и деструктор ============

BoolVector::BoolVector() : data(nullptr), numBits(0), numBytes(0) {}

BoolVector::BoolVector(size_t size, bool defaultValue) 
    : numBits(size), numBytes((size + 7) / 8) {
    data = new unsigned char[numBytes];
    
    // Инициализация всех байтов
    unsigned char initValue = defaultValue ? 0xFF : 0x00;
    for (size_t i = 0; i < numBytes; ++i) {
        data[i] = initValue;
    }
    
    // Обнуление лишних битов в последнем байте
    size_t bitsInLastByte = size % 8;
    if (bitsInLastByte != 0 && !defaultValue) {
        data[numBytes - 1] &= (1 << bitsInLastByte) - 1;
    } else if (bitsInLastByte != 0 && defaultValue) {
        data[numBytes - 1] |= ~((1 << bitsInLastByte) - 1);
    }
}

BoolVector::BoolVector(const BoolVector& other) 
    : numBits(other.numBits), numBytes(other.numBytes) {
    data = new unsigned char[numBytes];
    for (size_t i = 0; i < numBytes; ++i) {
        data[i] = other.data[i];
    }
}

BoolVector::~BoolVector() {
    delete[] data;
}

// ============ Операторы ============

BoolVector& BoolVector::operator=(const BoolVector& other) {
    if (this != &other) {
        delete[] data;
        
        numBits = other.numBits;
        numBytes = other.numBytes;
        
        data = new unsigned char[numBytes];
        for (size_t i = 0; i < numBytes; ++i) {
            data[i] = other.data[i];
        }
    }
    return *this;
}

BoolVector::Reference BoolVector::operator[](size_t index) {
    if (index >= numBits) {
        throw std::out_of_range("Index out of range");
    }
    return Reference(&data[byteIndex(index)], bitMask(index));
}

bool BoolVector::operator[](size_t index) const {
    if (index >= numBits) {
        throw std::out_of_range("Index out of range");
    }
    return (data[byteIndex(index)] & bitMask(index)) != 0;
}

// ============ Методы доступа ============

size_t BoolVector::size() const {
    return numBits;
}

bool BoolVector::empty() const {
    return numBits == 0;
}

// ============ Методы модификации ============

void BoolVector::resize(size_t newSize, bool defaultValue) {
    size_t newNumBytes = (newSize + 7) / 8;
    unsigned char* newData = new unsigned char[newNumBytes];
    
    // Копирование старых данных
    size_t copyBytes = std::min(numBytes, newNumBytes);
    for (size_t i = 0; i < copyBytes; ++i) {
        newData[i] = data[i];
    }
    
    // Инициализация новых байтов
    unsigned char initValue = defaultValue ? 0xFF : 0x00;
    for (size_t i = numBytes; i < newNumBytes; ++i) {
        newData[i] = initValue;
    }
    
    // Обнуление лишних битов в последнем байте при уменьшении размера
    if (newSize < numBits) {
        size_t bitsInLastByte = newSize % 8;
        if (bitsInLastByte != 0) {
            newData[newNumBytes - 1] &= (1 << bitsInLastByte) - 1;
        }
    }
    
    // Обработка случая, когда размер увеличивается, а последний байт нужно очистить
    if (newSize > numBits && numBits % 8 != 0) {
        size_t bitsInLastOldByte = numBits % 8;
        newData[numBytes - 1] |= ~((1 << bitsInLastOldByte) - 1);
        if (defaultValue) {
            // Дополнительные биты уже установлены в 1 через initValue
        } else {
            newData[numBytes - 1] &= (1 << bitsInLastOldByte) - 1;
        }
    }
    
    delete[] data;
    data = newData;
    numBits = newSize;
    numBytes = newNumBytes;
}

void BoolVector::push_back(bool value) {
    resize(numBits + 1, value);
}

void BoolVector::pop_back() {
    if (numBits > 0) {
        resize(numBits - 1);
    }
}

void BoolVector::clear() {
    delete[] data;
    data = nullptr;
    numBits = 0;
    numBytes = 0;
}

void BoolVector::fill(bool value) {
    unsigned char fillValue = value ? 0xFF : 0x00;
    for (size_t i = 0; i < numBytes; ++i) {
        data[i] = fillValue;
    }
    
    // Корректировка последнего байта
    size_t bitsInLastByte = numBits % 8;
    if (bitsInLastByte != 0 && !value) {
        data[numBytes - 1] &= (1 << bitsInLastByte) - 1;
    } else if (bitsInLastByte != 0 && value) {
        data[numBytes - 1] |= ~((1 << bitsInLastByte) - 1);
    }
}

// ============ Реализация Reference ============

BoolVector::Reference::Reference(unsigned char* byte, unsigned char mask) 
    : byte(byte), mask(mask) {}

BoolVector::Reference& BoolVector::Reference::operator=(bool value) {
    if (value) {
        *byte |= mask;
    } else {
        *byte &= ~mask;
    }
    return *this;
}

BoolVector::Reference::operator bool() const {
    return (*byte & mask) != 0;
}

BoolVector::Reference& BoolVector::Reference::operator=(const Reference& other) {
    *this = (bool)other;
    return *this;
}


